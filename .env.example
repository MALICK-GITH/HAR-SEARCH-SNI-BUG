# Local development should use the external Render PostgreSQL URL.
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE_NAME

# Render services running in the same private network can use the internal hostname instead.
# DATABASE_URL=postgresql://USERNAME:PASSWORD@INTERNAL_HOST/DATABASE_NAME

FLASK_SECRET_KEY=replace-with-a-long-random-secret
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
LOG_LEVEL=INFO
INMUX_REQUEST_TIMEOUT=45
HACKERTARGET_API_KEY=
